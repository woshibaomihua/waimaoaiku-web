{
  "redirects": [
    {
      "source": "/returns-policy.html",
      "destination": "/faq.html",
      "permanent": true
    },
    {
      "source": "/products/mobile-commercial-air-sterilizer.html",
      "destination": "/products.html",
      "permanent": true
    },
    {
      "source": "/air-purifier-for-smoke.html",
      "destination": "/solution-pet-smoke-air-purifier.html",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
